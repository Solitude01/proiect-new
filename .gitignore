# Python 虚拟环境与缓存
/.venv/
__pycache__/
*.pyc

# 二进制与执行文件
*.exe
*.dll
*.pyd
*.so
*.onnx

# 压缩包与大型镜像
*.iso
*.zip
*.rar
*.7z
*.pth

# IDE 配置文件
.idea/
.vscode/

